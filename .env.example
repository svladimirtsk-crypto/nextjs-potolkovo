# Установите true для работы без реального API (вернёт mock-данные)
MOCK_AI=false

# Токен доступа к Amvera Inference API
# Получить: https://id.amvera.ru → раздел LLM → скопировать токен
AMVERA_API_TOKEN=
# Base URL API Amvera
AMVERA_BASE_URL=https://kong-proxy.yc.amvera.ru/api/v1

# Модель: gpt-4.1 или gpt-5
AMVERA_MODEL=gpt-4.1

# ============================================================
# Site
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

