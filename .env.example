MOCK_AI=false
AMVERA_API_TOKEN=
AMVERA_BASE_URL=https://kong-proxy.yc.amvera.ru/api/v1
AMVERA_MODEL=gpt-4.1

# ============================================================
# Site
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=af2e2c48-e7c3-4301-923d-3fd5c57193a5

# Catalog source strategy:
# 0 -> snapshot only (default, stable for prod)
# 1 -> try live feed2 first, fallback to snapshot if invalid
CATALOG_LIVE_FEED2_ENABLED=0

# Strict live debug mode:
# 1 -> if live invalid, do not fallback to snapshot, return error
CATALOG_LIVE_FEED2_STRICT=0
